    "@shared/logger":               "*",
    "firebase-admin":               "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript":  "^5.0.0"
  }
}
