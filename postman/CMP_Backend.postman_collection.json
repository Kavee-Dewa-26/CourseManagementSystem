            },
            "url": { "raw": "{{baseUrl}}/semesters/{{semesterId}}/subjects" }
          }
        },
        {
          "name": "Publish Course",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}/publish" }
          }
        },
        {
          "name": "Student2 now sees PUBLISHED course (expect 200)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{student2Token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}" }
          }
        },
        {
          "name": "Unpublish Course → back to DRAFT",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}/unpublish" }
          }
        },
        {
          "name": "Re-publish Course",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}/publish" }
          }
        },
        {
          "name": "Update Subject 1",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Intro to Algorithms (Updated)\",\n  \"description\": \"Revised sorting and complexity module\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/subjects/{{subjectId}}" }
          }
        }
