              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/semesters/{{semesterId}}/subjects" }
          }
        },
        {
          "name": "Create Subject 2 — save response id as subjectId2",
          "event": [{
