{
  "info": {
    "name": "CMP Backend",
    "description": "Course Management Portal — all service endpoints via gateway :3000.\n\nLocal setup:\n1. Run: node scripts/seed-emulator.js  (seeds 4 test users)\n2. Import CMP_Local environment and select it\n3. Run '🔐 Sign In' requests to populate tokens\n4. Work through numbered folders in order for the full flow\n\nTest users (seeded by seed-emulator.js):\n  superadmin@cmp.com  SuperAdmin@123\n  admin@cmp.com       Admin@12345\n  student1@cmp.com    Student1@123   (pending_approval)\n  student2@cmp.com    Student2@123   (pre-approved)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{idToken}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Sign In (Get Tokens)",
      "description": "Hits the Firebase Auth emulator REST API. Tokens are auto-saved to environment variables.",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "Sign In — Super Admin",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.idToken) {",
                "  pm.environment.set('superAdminToken', j.idToken);",
                "  pm.environment.set('idToken', j.idToken);",
                "  console.log('superAdminToken saved');",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@cmp.com\",\n  \"password\": \"SuperAdmin@123\",\n  \"returnSecureToken\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{authBaseUrl}}/accounts:signInWithPassword?key={{firebaseWebApiKey}}" }
          }
        },
        {
          "name": "Sign In — Admin",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.idToken) {",
                "  pm.environment.set('adminToken', j.idToken);",
                "  pm.environment.set('idToken', j.idToken);",
                "  console.log('adminToken saved');",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cmp.com\",\n  \"password\": \"Admin@12345\",\n  \"returnSecureToken\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{authBaseUrl}}/accounts:signInWithPassword?key={{firebaseWebApiKey}}" }
          }
        },
        {
          "name": "Sign In — Student 1 (pending approval)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.idToken) {",
                "  pm.environment.set('studentToken', j.idToken);",
                "  pm.environment.set('idToken', j.idToken);",
                "  console.log('studentToken saved');",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@cmp.com\",\n  \"password\": \"Student1@123\",\n  \"returnSecureToken\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{authBaseUrl}}/accounts:signInWithPassword?key={{firebaseWebApiKey}}" }
          }
        },
        {
          "name": "Sign In — Student 2 / Test2 (pre-approved)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.idToken) {",
                "  pm.environment.set('student2Token', j.idToken);",
                "  pm.environment.set('idToken', j.idToken);",
                "  console.log('student2Token saved');",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student2@cmp.com\",\n  \"password\": \"Student2@123\",\n  \"returnSecureToken\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{authBaseUrl}}/accounts:signInWithPassword?key={{firebaseWebApiKey}}" }
          }
        }
      ]
    },

    {
      "name": "1️⃣ Auth Service",
      "description": "Register a brand-new student (test3). student1 and student2 are already seeded.\npassword rules: 10+ chars, uppercase, lowercase, number, special char.",
      "item": [
        {
          "name": "Register New Student (test3)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student3@cmp.com\",\n  \"password\": \"Student3@123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Three\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register" }
          }
        },
        {
          "name": "Register — duplicate email (expect 409)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@cmp.com\",\n  \"password\": \"Student1@123\",\n  \"firstName\": \"Dup\",\n  \"lastName\": \"Test\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register" }
          }
        },
        {
          "name": "Register — weak password (expect 400)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bad@cmp.com\",\n  \"password\": \"abc\",\n  \"firstName\": \"A\",\n  \"lastName\": \"B\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register" }
          }
        },
        {
          "name": "Password Reset",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@cmp.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/password-reset" }
          }
        },
        {
          "name": "Logout (student1)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{studentToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout" }
          }
        },
        {
          "name": "Track Login Failure",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@cmp.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/track-failure" }
          }
        }
      ]
    },

    {
      "name": "2️⃣ User Service — Me",
      "description": "Works for any signed-in role. GET /me returns user object directly (not wrapped in data:{}).",
      "item": [
        {
          "name": "Get My Profile (student1) — saves userId",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.uid) {",
                "  pm.environment.set('userId', j.uid);",
                "  console.log('userId saved:', j.uid);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{studentToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/me" }
          }
        },
        {
          "name": "Get My Profile (student2 / Test2) — saves student2Id",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.uid) {",
                "  pm.environment.set('student2Id', j.uid);",
                "  console.log('student2Id saved:', j.uid);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{student2Token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/me" }
          }
        },
        {
          "name": "Update My Profile (student2)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{student2Token}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Two Updated\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/me" }
          }
        },
        {
          "name": "Change Password (student2)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{student2Token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Student2@123\",\n  \"newPassword\": \"Student2@NewPass!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/me/change-password" }
          }
        },
        {
          "name": "No token (expect 401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/me" }
          }
        }
      ]
    },

    {
      "name": "3️⃣ User Service — Admin Manage Users",
      "description": "Requires admin token",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
      },
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users" }
          }
        },
        {
          "name": "Get User by UID (student1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}" }
          }
        },
        {
          "name": "Suspend student2",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/{{student2Id}}/suspend" }
          }
        },
        {
          "name": "Reactivate student2",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/{{student2Id}}/reactivate" }
          }
        },
        {
          "name": "Student tries to list users (expect 403)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{student2Token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users" }
          }
        }
      ]
    },

