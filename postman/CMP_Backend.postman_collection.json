          }
        }
      ]
    },

    {
      "name": "5️⃣ Course Service — Build a Course",
      "description": "Admin builds: Course → Semester → Subject × 2, then Publishes.\nStudents see DRAFT as 404; admin sees all states.",
      "item": [
        {
          "name": "List Courses (public — no auth)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/courses" }
          }
        },
        {
          "name": "Create Course — saves courseId",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.id) {",
                "  pm.environment.set('courseId', j.id);",
                "  console.log('courseId saved:', j.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Introduction to Computer Science\",\n  \"description\": \"Foundational CS concepts for beginners\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/courses" }
          }
        },
        {
          "name": "Student2 tries to view DRAFT course (expect 404)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{student2Token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}" }
          }
        },
        {
          "name": "Admin views DRAFT course (expect 200)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}" }
          }
        },
        {
          "name": "Update Course",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Introduction to CS (Revised)\",\n  \"description\": \"Updated description\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}" }
          }
        },
        {
          "name": "Publish with no semesters (expect 422)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}/publish" }
          }
        },
        {
          "name": "Create Semester — saves semesterId",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "if (j.id) {",
                "  pm.environment.set('semesterId', j.id);",
                "  console.log('semesterId saved:', j.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Semester 1\",\n  \"description\": \"Core modules for the first term\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}/semesters" }
          }
        },
        {
          "name": "Publish with no subjects (expect 422)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/courses/{{courseId}}/publish" }
          }
        },
        {
          "name": "Create Subject 1 — saves subjectId",
          "event": [{
            "listen": "test",
