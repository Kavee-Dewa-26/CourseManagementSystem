{
  "id": "cmp-local-env",
  "name": "CMP — Local (Emulator)",
  "_postman_variable_scope": "environment",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "enabled": true,
      "description": "Gateway entry point"
    },
    {
      "key": "authBaseUrl",
      "value": "http://127.0.0.1:9099/identitytoolkit.googleapis.com/v1",
      "enabled": true,
      "description": "Firebase Auth emulator REST base — change to https://identitytoolkit.googleapis.com/v1 for production"
    },
    {
      "key": "firebaseWebApiKey",
      "value": "fake-key",
      "enabled": true,
      "description": "Any non-empty string works against the emulator"
    },
    {
      "key": "superAdminToken",
      "value": "",
      "enabled": true
    },
    {
      "key": "adminToken",
      "value": "",
      "enabled": true
    },
    {
      "key": "studentToken",
      "value": "",
      "enabled": true,
      "description": "student1@cmp.com (pending_approval — run approval flow first)"
    },
    {
      "key": "student2Token",
      "value": "",
      "enabled": true,
      "description": "student2@cmp.com (pre-approved — ready for enroll/progress tests immediately)"
    },
    {
      "key": "idToken",
      "value": "",
      "enabled": true,
      "description": "Active token — overwritten by each sign-in request"
    },
    {
      "key": "userId",
      "value": "",
      "enabled": true,
      "description": "student1 UID (populated by GET /me after signing in as student1)"
    },
    {
      "key": "student2Id",
      "value": "",
      "enabled": true,
      "description": "student2 UID (populated by GET /me after signing in as student2)"
    },
    {
      "key": "adminUserId",
      "value": "",
      "enabled": true,
      "description": "Newly created admin UID"
    },
    {
      "key": "courseId",
      "value": "",
      "enabled": true
    },
    {
      "key": "semesterId",
      "value": "",
      "enabled": true
    },
    {
      "key": "subjectId",
      "value": "",
      "enabled": true,
      "description": "Subject 1"
    },
    {
      "key": "subjectId2",
      "value": "",
      "enabled": true,
      "description": "Subject 2"
    },
    {
      "key": "enrollmentId",
      "value": "",
      "enabled": true,
      "description": "student1 enrollment"
    },
    {
      "key": "enrollmentId2",
      "value": "",
      "enabled": true,
      "description": "student2 enrollment"
    },
    {
      "key": "registrationId",
      "value": "",
      "enabled": true,
      "description": "student1 registration (pending)"
    },
    {
      "key": "notificationId",
      "value": "",
      "enabled": true
    },
    {
      "key": "attachmentId",
      "value": "",
      "enabled": true
    }
  ]
}
