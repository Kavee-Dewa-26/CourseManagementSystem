{
  "name": "slp-backend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared/*",
    "packages/*"
  ],
  "scripts": {
    "dev:all": "bash scripts/start.sh",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "type-check": "tsc --noEmit --project tsconfig.base.json && npm run type-check --workspaces --if-present",
    "lint": "eslint 'packages/**/src/**/*.ts' --max-warnings=0",
    "format": "prettier --write 'packages/**/*.{ts,json}'",
    "test": "jest --config jest.config.ts",
    "test:integration": "jest --config jest.integration.config.ts",
    "test:e2e": "jest --config jest.e2e.config.ts"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "wait-on": "^9.0.5"
  }
}
