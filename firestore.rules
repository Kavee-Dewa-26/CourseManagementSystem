rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function hasRole(role) { return isAuthenticated() && request.auth.token.role == role; }
    function isAdmin() { return hasRole('admin') || hasRole('super_admin'); }
    function isSuperAdmin() { return hasRole('super_admin'); }
    function isOwner(uid) { return isAuthenticated() && request.auth.uid == uid; }

    match /audit_log/{entry} {
      allow read:   if isSuperAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /outbox/{entry} { allow read, write: if false; }

    match /users/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /courses/{courseId} {
      allow read:  if (resource.data.state == 'published' && resource.data.deletedAt == null) || isAdmin();
      allow write: if false;
    }

    match /semesters/{semesterId} { allow read: if isAdmin(); allow write: if false; }
    match /subjects/{subjectId} { allow read: if isAuthenticated(); allow write: if false; }
    match /attachments/{attachmentId} { allow read: if isAuthenticated(); allow write: if false; }

    match /enrollments/{enrollmentId} {
      allow read:  if isOwner(resource.data.studentUid) || isAdmin();
      allow write: if false;
    }

    match /registrations/{registrationId} { allow read: if isAdmin(); allow write: if false; }
    match /loginAttempts/{email} { allow read, write: if false; }

    match /progress/{progressId} {
      allow read:  if isOwner(resource.data.studentUid) || isAdmin();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read:  if isOwner(resource.data.userUid);
      allow write: if false;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
